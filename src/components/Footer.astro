---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentYear = new Date().getFullYear();

const services = [
  { label: 'Business Websites', href: `${base}/services#business-websites` },
  { label: 'Ecommerce Websites', href: `${base}/services#ecommerce` },
  { label: 'Custom Web Systems', href: `${base}/services#custom-systems` },
  { label: 'Inventory Systems', href: `${base}/services#custom-systems` },
  { label: 'Booking Systems', href: `${base}/services#custom-systems` },
  { label: 'Website Maintenance', href: `${base}/services#maintenance` },
];

const company = [
  { label: 'About', href: `${base}/about` },
  { label: 'Portfolio', href: `${base}/portfolio` },
  { label: 'Live Demos', href: `${base}/demos` },
  { label: 'Industries', href: `${base}/industries` },
  { label: 'Contact', href: `${base}/contact` },
];

const industries = [
  { label: 'Clinics & Healthcare', href: `${base}/industries#healthcare` },
  { label: 'Retail & Ecommerce', href: `${base}/industries#retail` },
  { label: 'Restaurants & Hospitality', href: `${base}/industries#hospitality` },
  { label: 'Schools & Training', href: `${base}/industries#education` },
  { label: 'SMEs & Startups', href: `${base}/industries#smes` },
];
---

<footer class="bg-dark-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href={`${base}/`} class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 bg-primary-600 rounded-lg flex items-center justify-center">
            <span class="text-white font-extrabold text-sm">JW</span>
          </div>
          <span class="text-xl font-bold text-white tracking-tight">Jemweb</span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed mb-6">
          Websites and custom web systems for SMEs and growing businesses. From company websites to inventory systems — I build tools that help businesses grow.
        </p>
        <div class="flex items-center gap-4">
          <a
            href="https://wa.me/YOUR_NUMBER"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-green-600 transition-colors"
            aria-label="WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <a
            href="mailto:hello@jemweb.co"
            class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-primary-600 transition-colors"
            aria-label="Email"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-3">
          {services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-3">
          {company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Industries -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Industries</h3>
        <ul class="space-y-3">
          {industries.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Jemweb. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href={`${base}/contact`} class="text-sm text-gray-500 hover:text-white transition-colors">Get in Touch</a>
      </div>
    </div>
  </div>
</footer>
