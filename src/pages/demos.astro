---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Live Demos — Jemweb",
  "description": "Interactive demo systems showcasing inventory management, appointment booking, ecommerce, and admin dashboard capabilities.",
  "url": "https://jemweb.co/demos"
};

const demos = [
  {
    title: 'Inventory Management Demo',
    subtitle: 'For Retail Stores',
    description: 'A fully functional inventory dashboard showing how a retail store can manage products, track stock levels, receive low-stock alerts, and view analytics — all from one place.',
    features: [
      'Product list with search & filter',
      'Add, edit, and delete products',
      'Real-time stock level tracking',
      'Low-stock alert indicators',
      'Category management',
      'Dashboard with analytics overview',
    ],
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
    color: 'from-blue-500 to-indigo-600',
    status: 'Live',
  },
  {
    title: 'Clinic Appointment Booking',
    subtitle: 'For Healthcare Clinics',
    description: 'An online appointment booking system where patients can view available slots, select a doctor, book appointments, and receive confirmation — while the clinic manages everything from an admin panel.',
    features: [
      'Calendar-based booking interface',
      'Doctor selection & availability',
      'Patient information form',
      'Booking confirmation',
      'Admin dashboard for management',
      'Appointment history',
    ],
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    color: 'from-emerald-500 to-teal-600',
    status: 'Live',
  },
  {
    title: 'Ecommerce Store Demo',
    subtitle: 'For Online Retailers',
    description: 'A sample online store demonstrating a complete shopping experience — from browsing products and adding to cart, to checkout and order confirmation.',
    features: [
      'Product catalog with categories',
      'Product detail pages',
      'Shopping cart functionality',
      'Checkout flow',
      'Order summary',
      'Responsive mobile design',
    ],
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>`,
    color: 'from-orange-500 to-red-600',
    status: 'Live',
  },
  {
    title: 'Admin Dashboard Demo',
    subtitle: 'For Business Operations',
    description: 'A business operations dashboard showing how orders, products, customers, and revenue can be managed from a single admin interface with charts and tables.',
    features: [
      'Overview with key metrics',
      'Orders management table',
      'Customer list',
      'Revenue charts',
      'Quick actions',
      'Role-based navigation',
    ],
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
    color: 'from-purple-500 to-violet-600',
    status: 'Live',
  },
];
---

<BaseLayout
  title="Live Demos — Jemweb | Interactive Business System Demos"
  description="Explore live interactive demos of inventory systems, appointment booking, ecommerce stores, and admin dashboards. See what I can build for your business."
  schema={schema}
>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-dark-950 via-dark-900 to-primary-950 text-white py-20 sm:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <div class="absolute top-10 right-20 w-80 h-80 bg-accent-500 rounded-full blur-[128px]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block text-sm font-semibold uppercase tracking-wider text-accent-400 mb-4">Live Demos</span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
        Business system demos
      </h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed">
        These interactive demos prove I can build real functionality — not just static pages. Explore them to see what's possible for your business.
      </p>
    </div>
  </section>

  <!-- Demo Cards -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {demos.map((demo, i) => (
          <div class="reveal group" style={`animation-delay: ${i * 0.1}s;`}>
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-500 hover:-translate-y-1 h-full flex flex-col">
              <!-- Header -->
              <div class={`bg-gradient-to-br ${demo.color} p-6 sm:p-8 text-white`}>
                <div class="flex items-center justify-between mb-4">
                  <div class="w-14 h-14 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center">
                    <Fragment set:html={demo.icon} />
                  </div>
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/20 backdrop-blur-sm rounded-full text-xs font-semibold">
                    <span class="w-2 h-2 bg-green-300 rounded-full animate-pulse"></span>
                    {demo.status}
                  </span>
                </div>
                <h2 class="text-2xl font-extrabold mb-1">{demo.title}</h2>
                <p class="text-sm text-white/70">{demo.subtitle}</p>
              </div>

              <!-- Body -->
              <div class="p-6 sm:p-8 flex-1 flex flex-col">
                <p class="text-gray-600 leading-relaxed mb-6">{demo.description}</p>

                <div class="mb-6 flex-1">
                  <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-3">Features Demonstrated</h3>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                    {demo.features.map((feature) => (
                      <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-sm text-gray-700">{feature}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <div class="flex flex-wrap gap-3 pt-4 border-t border-gray-100">
                  <a
                    href={`${base}/contact`}
                    class="inline-flex items-center px-5 py-2.5 bg-primary-600 text-white text-sm font-semibold rounded-xl hover:bg-primary-700 transition-all duration-200 shadow-sm hover:shadow-md"
                  >
                    Build Something Like This
                  </a>
                  <a
                    href="https://wa.me/YOUR_NUMBER?text=Hi%20Jemweb%2C%20I%20saw%20your%20demo%20and%20I%27m%20interested."
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center px-5 py-2.5 bg-green-50 text-green-700 text-sm font-semibold rounded-xl hover:bg-green-100 transition-colors"
                  >
                    <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Ask on WhatsApp
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mini Inline Inventory Demo -->
  <section class="py-20 sm:py-28 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal">
        <SectionHeading
          subtitle="Interactive Preview"
          title="Inventory system — quick preview"
          description="This mini demo shows how a retail store inventory system works. Search, filter, and see stock status at a glance."
        />
      </div>

      <!-- Inline Demo Widget -->
      <div class="mt-12 reveal">
        <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-lg">
          <!-- Demo Header Bar -->
          <div class="flex items-center gap-2 px-4 py-3 bg-gray-900 border-b border-gray-700">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <div class="flex-1 text-center">
              <span class="text-xs text-gray-400 font-mono">inventory.jemweb.co/dashboard</span>
            </div>
          </div>

          <!-- Demo Content -->
          <div class="p-6" id="inventory-demo">
            <!-- Stats -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
              <div class="bg-blue-50 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-blue-700">156</p>
                <p class="text-xs text-blue-600 font-medium mt-1">Total Products</p>
              </div>
              <div class="bg-green-50 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-green-700">128</p>
                <p class="text-xs text-green-600 font-medium mt-1">In Stock</p>
              </div>
              <div class="bg-yellow-50 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-yellow-700">21</p>
                <p class="text-xs text-yellow-600 font-medium mt-1">Low Stock</p>
              </div>
              <div class="bg-red-50 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-red-700">7</p>
                <p class="text-xs text-red-600 font-medium mt-1">Out of Stock</p>
              </div>
            </div>

            <!-- Search Bar -->
            <div class="flex flex-col sm:flex-row gap-3 mb-4">
              <div class="relative flex-1">
                <svg class="w-5 h-5 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input
                  type="text"
                  placeholder="Search products..."
                  id="demo-search"
                  class="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                />
              </div>
              <select id="demo-filter" class="px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
                <option value="all">All Status</option>
                <option value="in-stock">In Stock</option>
                <option value="low-stock">Low Stock</option>
                <option value="out-of-stock">Out of Stock</option>
              </select>
            </div>

            <!-- Product Table -->
            <div class="overflow-x-auto">
              <table class="w-full text-sm" id="demo-table">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="text-left py-3 px-4 font-semibold text-gray-600">Product</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-600">SKU</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-600">Stock</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-600">Status</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-600">Price</th>
                  </tr>
                </thead>
                <tbody id="demo-tbody">
                  <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors" data-status="in-stock" data-name="wireless keyboard">
                    <td class="py-3 px-4 font-medium text-gray-900">Wireless Keyboard</td>
                    <td class="py-3 px-4 text-gray-500 font-mono">SKU-001</td>
                    <td class="py-3 px-4 text-gray-700">48</td>
                    <td class="py-3 px-4"><span class="px-2.5 py-1 bg-green-100 text-green-700 text-xs font-semibold rounded-full">In Stock</span></td>
                    <td class="py-3 px-4 text-gray-700">$29.99</td>
                  </tr>
                  <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors" data-status="low-stock" data-name="usb-c hub adapter">
                    <td class="py-3 px-4 font-medium text-gray-900">USB-C Hub Adapter</td>
                    <td class="py-3 px-4 text-gray-500 font-mono">SKU-002</td>
                    <td class="py-3 px-4 text-gray-700">5</td>
                    <td class="py-3 px-4"><span class="px-2.5 py-1 bg-yellow-100 text-yellow-700 text-xs font-semibold rounded-full">Low Stock</span></td>
                    <td class="py-3 px-4 text-gray-700">$34.99</td>
                  </tr>
                  <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors" data-status="in-stock" data-name="mechanical mouse">
                    <td class="py-3 px-4 font-medium text-gray-900">Mechanical Mouse</td>
                    <td class="py-3 px-4 text-gray-500 font-mono">SKU-003</td>
                    <td class="py-3 px-4 text-gray-700">72</td>
                    <td class="py-3 px-4"><span class="px-2.5 py-1 bg-green-100 text-green-700 text-xs font-semibold rounded-full">In Stock</span></td>
                    <td class="py-3 px-4 text-gray-700">$19.99</td>
                  </tr>
                  <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors" data-status="out-of-stock" data-name="monitor stand riser">
                    <td class="py-3 px-4 font-medium text-gray-900">Monitor Stand Riser</td>
                    <td class="py-3 px-4 text-gray-500 font-mono">SKU-004</td>
                    <td class="py-3 px-4 text-gray-700">0</td>
                    <td class="py-3 px-4"><span class="px-2.5 py-1 bg-red-100 text-red-700 text-xs font-semibold rounded-full">Out of Stock</span></td>
                    <td class="py-3 px-4 text-gray-700">$44.99</td>
                  </tr>
                  <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors" data-status="low-stock" data-name="webcam hd 1080p">
                    <td class="py-3 px-4 font-medium text-gray-900">Webcam HD 1080p</td>
                    <td class="py-3 px-4 text-gray-500 font-mono">SKU-005</td>
                    <td class="py-3 px-4 text-gray-700">3</td>
                    <td class="py-3 px-4"><span class="px-2.5 py-1 bg-yellow-100 text-yellow-700 text-xs font-semibold rounded-full">Low Stock</span></td>
                    <td class="py-3 px-4 text-gray-700">$59.99</td>
                  </tr>
                  <tr class="hover:bg-gray-50 transition-colors" data-status="in-stock" data-name="laptop sleeve 15 inch">
                    <td class="py-3 px-4 font-medium text-gray-900">Laptop Sleeve 15"</td>
                    <td class="py-3 px-4 text-gray-500 font-mono">SKU-006</td>
                    <td class="py-3 px-4 text-gray-700">35</td>
                    <td class="py-3 px-4"><span class="px-2.5 py-1 bg-green-100 text-green-700 text-xs font-semibold rounded-full">In Stock</span></td>
                    <td class="py-3 px-4 text-gray-700">$24.99</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="text-xs text-gray-400 text-center mt-4">This is a live interactive demo. Try searching or filtering above.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-28 bg-gradient-to-br from-primary-600 to-primary-800 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-96 h-96 bg-white rounded-full blur-[128px]"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal">
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-6">
          Impressed? Let's build something for your business
        </h2>
        <p class="text-lg text-primary-100 leading-relaxed mb-10 max-w-2xl mx-auto">
          These demos are just a glimpse. I can build custom systems tailored exactly to your business needs.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://wa.me/YOUR_NUMBER?text=Hi%20Jemweb%2C%20I%20checked%20out%20your%20demos%20and%20I%20want%20something%20similar."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-7 py-3.5 bg-green-500 text-white font-semibold rounded-xl hover:bg-green-400 transition-all duration-300 shadow-lg hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat on WhatsApp
          </a>
          <a href={`${base}/contact`} class="inline-flex items-center px-7 py-3.5 bg-white text-primary-700 font-semibold rounded-xl hover:bg-primary-50 transition-all duration-300 shadow-lg hover:-translate-y-0.5">
            Request a Quote
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById('demo-search') as HTMLInputElement;
  const filterSelect = document.getElementById('demo-filter') as HTMLSelectElement;
  const tbody = document.getElementById('demo-tbody');

  function filterTable() {
    if (!tbody) return;
    const search = searchInput?.value.toLowerCase() || '';
    const status = filterSelect?.value || 'all';
    const rows = tbody.querySelectorAll('tr');

    rows.forEach((row) => {
      const name = row.getAttribute('data-name') || '';
      const rowStatus = row.getAttribute('data-status') || '';
      const matchesSearch = name.includes(search);
      const matchesStatus = status === 'all' || rowStatus === status;
      (row as HTMLElement).style.display = matchesSearch && matchesStatus ? '' : 'none';
    });
  }

  searchInput?.addEventListener('input', filterTable);
  filterSelect?.addEventListener('change', filterTable);
</script>
