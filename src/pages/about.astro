---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Jemweb",
  "description": "Learn about Jemweb — a web designer and developer specializing in business websites, ecommerce stores, and custom web systems for SMEs.",
  "url": "https://jemweb.co/about"
};

const values = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Reliability',
    description: 'I deliver what I promise, on time, and I stand behind my work with ongoing support.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: 'Performance First',
    description: 'Every website I build is optimized for speed, mobile responsiveness, and search engine visibility.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
    title: 'Business-Minded',
    description: 'I think about your users, your revenue, and your operations — not just pixels and code.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
    title: 'Clear Communication',
    description: 'No jargon, no surprises. I keep you informed at every stage of the project.',
  },
];

const skills = [
  { category: 'Frontend', items: ['HTML5', 'CSS3', 'JavaScript', 'TypeScript', 'React', 'Next.js', 'Astro', 'Tailwind CSS'] },
  { category: 'Backend', items: ['Node.js', 'Python', 'Express', 'REST APIs'] },
  { category: 'Database', items: ['PostgreSQL', 'MySQL', 'MongoDB', 'Supabase'] },
  { category: 'Tools', items: ['Git', 'Figma', 'VS Code', 'Vercel', 'Netlify'] },
];
---

<BaseLayout
  title="About — Jemweb | Web Designer & Developer for SMEs"
  description="I'm a web designer and developer specializing in business websites, ecommerce stores, and custom web systems for SMEs and growing businesses."
  schema={schema}
>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-dark-950 via-dark-900 to-primary-950 text-white py-20 sm:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <div class="absolute top-20 right-10 w-72 h-72 bg-primary-600 rounded-full blur-[128px]"></div>
      <div class="absolute bottom-10 left-20 w-64 h-64 bg-accent-500 rounded-full blur-[128px]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block text-sm font-semibold uppercase tracking-wider text-primary-300 mb-4">About Me</span>
          <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-6">
            I help businesses move from outdated systems to clean, useful digital solutions
          </h1>
          <p class="text-lg text-gray-300 leading-relaxed mb-8">
            I'm a web designer and developer who specializes in building websites and custom web systems for SMEs, ecommerce brands, clinics, and growing businesses. I don't just make things look good — I build tools that help businesses sell, organize, and operate better.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={`${base}/services`} class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-500 transition-all duration-300 shadow-lg shadow-primary-600/25 hover:-translate-y-0.5">
              View Services
            </a>
            <a href={`${base}/contact`} class="inline-flex items-center px-6 py-3 bg-white/10 text-white font-semibold rounded-xl hover:bg-white/20 transition-all duration-300 border border-white/10">
              Get in Touch
            </a>
          </div>
        </div>
        <div class="hidden lg:flex justify-center">
          <div class="relative">
            <div class="w-80 h-80 bg-gradient-to-br from-primary-600/30 to-accent-500/30 rounded-3xl backdrop-blur-sm border border-white/10 flex items-center justify-center">
              <div class="text-center">
                <div class="w-24 h-24 bg-primary-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
                  <span class="text-white font-extrabold text-3xl">JW</span>
                </div>
                <p class="text-white font-bold text-xl">Jemweb</p>
                <p class="text-gray-400 text-sm mt-1">Web Designer & Developer</p>
              </div>
            </div>
            <div class="absolute -top-4 -right-4 w-24 h-24 bg-accent-500/20 rounded-2xl backdrop-blur-sm border border-white/10 flex items-center justify-center">
              <span class="text-accent-400 font-bold text-xs text-center leading-tight">SME<br/>Focused</span>
            </div>
            <div class="absolute -bottom-4 -left-4 w-28 h-20 bg-primary-600/20 rounded-2xl backdrop-blur-sm border border-white/10 flex items-center justify-center">
              <span class="text-primary-300 font-bold text-xs text-center leading-tight">Full Stack<br/>Developer</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="reveal">
          <span class="inline-block text-sm font-semibold uppercase tracking-wider text-primary-600 mb-3">What I Specialize In</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight mb-6">
            Practical digital solutions for real businesses
          </h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              I design and build websites and web systems that go beyond aesthetics. Every project I take on is designed to solve a real business problem — whether that's generating more leads, managing inventory, taking bookings, or selling products online.
            </p>
            <p>
              Unlike many web designers who only think about visuals, I understand business functionality. I can think about bookings, orders, stock management, dashboards, user roles, admin controls, and workflows. That means I can serve clients who need simple professional websites as well as those who need complex backend systems.
            </p>
            <p>
              I work with businesses across various industries — from clinics and retail stores to restaurants and logistics companies. This gives me a broad understanding of what different businesses need from their online presence.
            </p>
          </div>
        </div>

        <div class="reveal">
          <div class="bg-gray-50 rounded-2xl p-8">
            <h3 class="text-lg font-bold text-gray-900 mb-6">What makes me different</h3>
            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-primary-600 font-bold text-sm">1</span>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-1">I build both simple and advanced solutions</h4>
                  <p class="text-sm text-gray-600">From a one-page company website to a full inventory management system — I handle the full range.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-primary-600 font-bold text-sm">2</span>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-1">I understand business functionality</h4>
                  <p class="text-sm text-gray-600">I think about how your business actually operates and build tools that fit into your workflow.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-primary-600 font-bold text-sm">3</span>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-1">I serve multiple industries</h4>
                  <p class="text-sm text-gray-600">Healthcare, retail, hospitality, education, logistics — I understand industry-specific needs.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-primary-600 font-bold text-sm">4</span>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-1">Inventory systems are a strong niche</h4>
                  <p class="text-sm text-gray-600">This is a serious business capability — stock management dashboards are one of my featured strengths.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 sm:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal">
        <SectionHeading
          subtitle="My Approach"
          title="Values that guide my work"
          description="Every project is built on these core principles — ensuring you get a reliable, high-quality result."
        />
      </div>

      <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((value, i) => (
          <div class="reveal bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-lg hover:border-primary-200 transition-all duration-300 hover:-translate-y-1" style={`animation-delay: ${i * 0.1}s;`}>
            <div class="w-12 h-12 bg-primary-50 rounded-xl flex items-center justify-center text-primary-600 mb-4">
              <Fragment set:html={value.icon} />
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{value.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal">
        <SectionHeading
          subtitle="Technical Skills"
          title="Technologies I work with"
          description="I use modern, industry-standard technologies to build fast, secure, and scalable digital solutions."
        />
      </div>

      <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {skills.map((group, i) => (
          <div class="reveal" style={`animation-delay: ${i * 0.1}s;`}>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-primary-600 mb-4">{group.category}</h3>
            <div class="space-y-2">
              {group.items.map((item) => (
                <div class="flex items-center gap-2.5 py-2 px-3 bg-gray-50 rounded-lg hover:bg-primary-50 transition-colors">
                  <div class="w-1.5 h-1.5 bg-primary-500 rounded-full"></div>
                  <span class="text-sm font-medium text-gray-700">{item}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-28 bg-gradient-to-br from-primary-600 to-primary-800 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full blur-[128px]"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal">
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-6">
          Ready to work together?
        </h2>
        <p class="text-lg text-primary-100 leading-relaxed mb-10 max-w-2xl mx-auto">
          Whether you need a company website, ecommerce store, or custom business system — let's discuss your project and build the right solution.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://wa.me/YOUR_NUMBER?text=Hi%20Jemweb%2C%20I%27d%20like%20to%20discuss%20a%20project."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-7 py-3.5 bg-green-500 text-white font-semibold rounded-xl hover:bg-green-400 transition-all duration-300 shadow-lg hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat on WhatsApp
          </a>
          <a href={`${base}/contact`} class="inline-flex items-center px-7 py-3.5 bg-white text-primary-700 font-semibold rounded-xl hover:bg-primary-50 transition-all duration-300 shadow-lg hover:-translate-y-0.5">
            Request a Quote
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
